{
    "app": [
        {
            "title": "Friday Night Funkin' - Lime Engine",
            "main": "funkin.backend.system.Main",
            "file": "LimeEngine",
            "packageName": "com.glitchmaster.limeengine",
            "package": "com.glitchmaster.limeengine",
            "version": "Test 0.0.1",
            "company": "GlitchMaster & JoaoBanana"
        },
        {
            "preloader": "java.system.FlxPreloader"
        }
    ],
    "haxedef": [
        {
            "name": "SAVE_PATH",
            "value": "LimeEngine"
        },
        {
            "name": "SAVE_NAME",
            "value": "save-default"
        },
        {
            "name": "SAVE_OPTIONS_PATH",
            "value": "LimeEngine"
        },
        {
            "name": "SAVE_OPTIONS_NAME",
            "value": "options"
        },
        {
            "name": "REGION"
        },
        {
            "name": "HSCRIPT_ABSTRACT_SUPPORT",
            "unless": "STRIPPED_COMPILE"
        },
        {
            "name": "ALLOW_MULTITHREADING",
            "unless": "web || flash"
        },
        {
            "name": "MOD_SUPPORT",
            "unless": "web"
        },
        {
            "name": "TRANSLATIONS_SUPPORT"
        },
        {
            "name": "GLOBAL_SCRIPT"
        },
        {
            "name": "SOFTCODED_STATES"
        },
        {
            "name": "NDLLS_SUPPORTED",
            "unless": "web || iphonesim || hl"
        },
        {
            "name": "disable-version-check"
        },
        {
            "name": "no-deprecation-warnings"
        },
        {
            "name": "DISCORD_DISABLE_IO_THREAD",
            "if": "DISCORD_RPC"
        },
        {
            "name": "FLX_NO_FOCUS_LOST_SCREEN"
        },
        {
            "name": "FLX_NO_DEBUG",
            "unless": "debug"
        },
        {
            "name": "analyzer-optimize",
            "unless": "debug"
        },
        {
            "name": "VIDEO_CUTSCENES",
            "if": "VIDEO_CUTSCENES"
        },
        {
            "name": "UPDATE_CHECKING",
            "if": "UPDATE_CHECKING"
        },
        {
            "name": "DISCORD_RPC",
            "if": "DISCORD_RPC"
        },
        {
            "name": "SHOW_BUILD_ON_FPS",
            "if": "SHOW_BUILD_ON_FPS"
        },
        {
            "name": "SOFTCODED_CLASSES",
            "if": "SOFTCODED_CLASSES"
        },
        {
            "name": "USE_ADAPTED_ASSETS",
            "if": "USE_ADAPTED_ASSETS"
        },
        {
            "name": "openfl_dpi_aware",
            "if": "openfl_dpi_aware"
        },
        {
            "name": "message.reporting",
            "value": "pretty"
        },
        {
            "name": "HXCPP_M32",
            "if": "32bit"
        },
        {
            "name": "HXCPP_DEBUG_LINK",
            "if": "debug"
        },
        {
            "name": "HXCPP_CHECK_POINTER"
        },
        {
            "name": "HXCPP_STACK_LINE"
        },
        {
            "name": "HXCPP_CATCH_SEGV"
        },
        {
            "name": "hscriptPos"
        },
        {
            "name": "EXPERIMENTAL_FLXGRAPHIC_DESTROY_FIX"
        }
    ],
    "set": [
        {
            "name": "APP_ID",
            "value": "0x0100f6c013bbc000"
        },
        {
            "name": "SWF_VERSION",
            "value": "11.8"
        },
        {
            "name": "BUILD_DIR",
            "value": "export/debug",
            "if": "debug"
        },
        {
            "name": "BUILD_DIR",
            "value": "export/release",
            "unless": "debug"
        },
        {
            "name": "BUILD_DIR",
            "value": "export/debug-32bit",
            "if": "debug 32bit"
        },
        {
            "name": "BUILD_DIR",
            "value": "export/release-32bit",
            "if": "32bit",
            "unless": "debug"
        },
        {
            "name": "BUILD_DIR",
            "value": "latest/",
            "if": "beta"
        }
    ],
    "window": [
        {
            "width": "1280",
            "height": "720",
            "background": "#000000",
            "hardware": "true",
            "vsync": "false"
        },
        {
            "if": "html5",
            "resizable": "true"
        },
        {
            "if": "desktop",
            "orientation": "landscape",
            "fullscreen": "false",
            "resizable": "true",
            "vsync": "false"
        },
        {
            "if": "mac",
            "allow-high-dpi": "true"
        },
        {
            "if": "mobile",
            "orientation": "landscape",
            "fullscreen": "true",
            "width": "0",
            "height": "0",
            "resizable": "false"
        },
        {
            "if": "switch",
            "orientation": "landscape",
            "fullscreen": "true",
            "width": "0",
            "height": "0",
            "resizable": "true"
        }
    ],
    "define": [
        {
            "name": "UPDATE_CHECKING",
            "unless": "web || hl || neko || debug"
        },
        {
            "name": "MODCHARTING_FEATURES",
            "unless": "STRIPPED_COMPILE"
        },
        {
            "name": "GITHUB_API",
            "unless": "web || hl"
        },
        {
            "name": "COMPILE_ALL_CLASSES",
            "unless": "STRIPPED_COMPILE"
        },
        {
            "name": "CUSTOM_CLASSES",
            "unless": "STRIPPED_COMPILE"
        },
        {
            "name": "USE_ADAPTED_ASSETS",
            "unless": "web"
        },
        {
            "name": "THREE_D_SUPPORT",
            "unless": "STRIPPED_COMPILE"
        },
        {
            "name": "NAPE_ENABLED",
            "unless": "STRIPPED_COMPILE"
        },
        {
            "name": "SHOW_BUILD_ON_FPS"
        },
        {
            "name": "DARK_MODE_WINDOW"
        },
        {
            "name": "FLX_NO_GENERIC"
        },
        {
            "name": "disable-version-check"
        },
        {
            "name": "PRELOAD_ALL",
            "unless": "web"
        },
        {
            "name": "NO_PRELOAD_ALL",
            "unless": "PRELOAD_ALL"
        }
    ],
    "section": [
        {
            "if": "cpp",
            "define": [
                {
                    "name": "DISCORD_RPC",
                    "if": "desktop"
                }
            ]
        },
        {
            "if": "cpp",
            "define": [
                {
                    "name": "VIDEO_CUTSCENES",
                    "if": "desktop || android"
                }
            ]
        },
        {
            "unless": "TEST_BUILD",
            "assets": [
                {
                    "path": "assets/",
                    "rename": "assets",
                    "exclude": "*.ogg",
                    "if": "web"
                },
                {
                    "path": "assets/",
                    "rename": "assets",
                    "exclude": "*.mp3",
                    "unless": "web"
                },
                {
                    "path": "mods",
                    "rename": "mods",
                    "embed": "false"
                }
            ]
        },
        {
            "if": "desktop",
            "assets": [
                {
                    "path": "building/alsoft.txt",
                    "rename": "plugins/alsoft.ini",
                    "type": "text",
                    "if": "windows"
                },
                {
                    "path": "building/alsoft.txt",
                    "rename": "plugins/alsoft.conf",
                    "type": "text",
                    "unless": "windows"
                }
            ]
        },
        {
            "if": "MODCHARTING_FEATURES",
            "haxedef": [
                {
                    "name": "FM_ENGINE",
                    "value": "ORANGE"
                },
                {
                    "name": "FM_ENGINE_VERSION",
                    "value": "1.0"
                }
            ],
            "haxelib": [
                {
                    "name": "funkin-modchart"
                }
            ],
            "haxeflag": [
                {
                    "name": "--macro",
                    "value": "modchart.backend.macros.Macro.includeFiles()"
                }
            ]
        },
        {
            "if": "COMPILE_ALL_CLASSES",
            "haxeflag": [
                {
                    "name": "-dce",
                    "value": "no"
                },
                {
                    "name": "--macro",
                    "value": "funkin.backend.system.macros.Macros.addAdditionalClasses()"
                }
            ]
        }
    ],
    "Javalib": [
        {
            "name": "oran.ge"
        },
        {
            "name": "libGDX"
        }
    ],
    "source": [
        {
            "name": "source"
        }
    ],
    "library": [
        {
            "name": "assets",
            "preload": "true",
            "if": "PRELOAD_ALL"
        },
        {
            "name": "assets",
            "preload": "false",
            "if": "NO_PRELOAD_ALL"
        }
    ],
    "assets": [
        {
            "path": "art/readme.txt",
            "rename": "do NOT readme.txt"
        }
    ],
    "haxeflag": [
        {
            "name": "--macro",
            "value": "funkin.backend.system.macros.BuildInfo.printBuildInfo()"
        },
        {
            "name": "--macro",
            "value": "funkin.backend.system.macros.Macros.initMacros()"
        }
    ],
    "icon": [
        {
            "path": "art/icon16.png",
            "size": "16"
        },
        {
            "path": "art/icon32.png",
            "size": "24"
        },
        {
            "path": "art/icon32.png",
            "size": "32"
        },
        {
            "path": "art/icon64.png",
            "size": "40"
        },
        {
            "path": "art/icon64.png",
            "size": "48"
        },
        {
            "path": "art/icon64.png",
            "size": "64"
        },
        {
            "path": "art/iconOG.png",
            "size": "96"
        },
        {
            "path": "art/iconOG.png",
            "size": "128"
        },
        {
            "path": "art/iconOG.png",
            "size": "196"
        },
        {
            "path": "art/iconOG.png",
            "size": "256"
        },
        {
            "path": "art/iconOG.png",
            "size": "512"
        },
        {
            "path": "art/iconOG.png",
            "size": "768"
        },
        {
            "path": "art/iconOG.png",
            "size": "1024"
        }
    ],
    "setenv": [
        {
            "name": "HAXEPATH",
            "value": "./"
        }
    ]
}