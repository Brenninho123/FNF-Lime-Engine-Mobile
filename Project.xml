<?xml version="1.0" encoding="utf-8"?>
<project xmlns="http://lime.openfl.org/project/1.0.4" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://lime.openfl.org/project/1.0.4 http://lime.openfl.org/xsd/project-1.0.4.xsd">

	<app title="FNF: Lime Engine" file="LimeEngine" packageName="com.glitchmaster.limeengine" package="com.glitchmaster.limeengine" main="Main" version="Test 0.0.1" company="GlitchMaster & JoaoBanana" />

	<app preloader="flixel.system.FlxPreloader" />

	<set name="SWF_VERSION" value="11.8" />

	<define name="MODS_ALLOWED" if="desktop" />
	<define name="POLYSCRIPT_ALLOWED" if="desktop" />
	<define name="ACHIEVEMENTS_ALLOWED" />
	<define name="VIDEOS_ALLOWED" if="windows || linux || android || mac" unless="32bits"/>

	<window width="640" height="480" fps="60" background="#363636" hardware="true" vsync="true" />

	<window if="html5" resizable="true" />

	<window if="desktop" orientation="landscape" fullscreen="false" resizable="true" />

	<window if="mobile" orientation="landscape" fullscreen="true" width="0" height="0" antialiasing="0" allow-shaders="true" require-shaders="false" depth-buffer="false" stencil-buffer="false" resizable="true" />

	<set name="BUILD_DIR" value="export" />
	<source path="source" />
	<assets path="assets" />

	<section if="MODS_ALLOWED">
		<assets path='example_mods' rename='mods' embed='false' type='template' unless="mac"/>
		<assets path='example_mods' rename='mods' embed='false' if="mac"/>
	</section>

	<haxelib name="flixel" />
	<haxelib name="hxcs" />
	<haxelib name="lime" />
	<haxelib name="openfl" />
	<haxelib name="tjson" />
	<haxelib name="thx.core" />
	<haxelib name="thx.semver" />
	<haxelib name="format" />
	<haxelib name="flixel-tools" />
	<haxelib name="jsonpath" />
	<haxelib name="flxanimate" />

	<haxelib name="polymod" if="POLYSCRIPT_ALLOWED" />
	<haxelib name="hxvlc" if="VIDEOS_ALLOWED" />
	<haxelib name="extension-androidtools" if="android" />

	<haxedef name="FLX_NO_HEALTH" />

	<haxedef name="FLX_NO_MOUSE" if="mobile" />
	<haxedef name="FLX_NO_KEYBOARD" if="mobile" />
	<haxedef name="FLX_NO_TOUCH" if="desktop" />

	<haxedef name="FLX_NO_DEBUG" unless="debug" />

	<haxedef name="NAPE_RELEASE_BUILD" unless="debug" />

	<haxedef name="message.reporting" value="pretty" />

	<assets path='art/iconOG.png' rename='icon.png' if="linux || mac" />

	<icon path="art/icon16.png" size='16'/>
	<icon path="art/icon32.png" size='32'/>
	<icon path="art/icon64.png" size='64'/>
	<icon path="art/iconOG.png" />

	<config:android install-location="auto" gradle-arg="-Xmx4G" minimum-sdk-version="21" target-sdk-version="33" compile-sdk-version="33" architectures="armv7,arm64,x86_64" />
	<config:android gradle-arg="--stacktrace" />
	<config:android gradle-arg="--info" />
	<dependency name="androidx.appcompat:appcompat:1.6.1" if="android" />
	<certificate path="fnf.keystore" password="123456" alias="fnf" alias-password="123456" if="android" />

	<permission name="android.permission.INTERNET" if="android" />
	<permission name="android.permission.WRITE_EXTERNAL_STORAGE" if="android" />
	<permission name="android.permission.READ_EXTERNAL_STORAGE" if="android" />
	<permission name="android.permission.VIBRATE" if="android" />
	<permission name="android.permission.ACCESS_NETWORK_STATE" if="android" />

	<config:ios deployment-target="12.0" device="universal" allow-high-resolution="true" prerendered-icon="true" compiler-flags="-Wno-deprecated-declarations" />

	<config:ios team-identifier="" if="ios" />

</project>
